#!/bin/bash

interface=$(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1)

cat >/etc/iptables/rules.v4 <<EOF
*filter

# Default policy lebih aman
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# =========================
# LOOPBACK (WAJIB)
# =========================
-A INPUT -i lo -j ACCEPT

# =========================
# CONNECTION ESTABLISHED
# =========================
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# =========================
# PUBLIC ACCESS ONLY
# =========================
-A INPUT -p tcp --dport 22 -j ACCEPT
-A INPUT -p tcp --dport 80 -j ACCEPT
-A INPUT -p tcp --dport 443 -j ACCEPT
-A INPUT -p tcp --dport 3030 -j ACCEPT

# =========================
# VPN / OPTIONAL SERVICES
# =========================
-A INPUT -p tcp --dport 1194 -j ACCEPT

# =========================
# DROP PUBLIC ACCESS TO WS PORTS (IMPORTANT)
# =========================
-A INPUT -p tcp -m multiport --dports 2223,2222,10012,10015 -j DROP

# =========================
# OPTIONAL OTHER PUBLIC SERVICES (kalau memang perlu)
# =========================
-A INPUT -p tcp --dport 8080 -j ACCEPT
-A INPUT -p tcp --dport 8880 -j ACCEPT
-A INPUT -p tcp --dport 2080 -j ACCEPT
-A INPUT -p tcp --dport 2082 -j ACCEPT
COMMIT


*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

# DNS redirect (kalau kamu pakai dns tunnel)
-A PREROUTING -i $interface -p udp --dport 53 -j REDIRECT --to-ports 5300

# VPN NAT
-A POSTROUTING -s 10.8.0.0/24 -o $interface -j MASQUERADE
-A POSTROUTING -s 20.8.0.0/24 -o $interface -j MASQUERADE

COMMIT
EOF


cat >/etc/iptables/rules.v6 <<EOF
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

COMMIT
EOF


netfilter-persistent reload
systemctl restart netfilter-persistent
